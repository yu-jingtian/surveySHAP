install.packages("fastshap")
library(fastshap)
fit <- lm(mpg ~ cyl + disp + hp, data = mtcars)
X <- mtcars[, c("cyl","disp","hp")]
shap <- fastshap::explain(
object = fit,
X = X,
pred_wrapper = function(object, newdata) {
predict(object, newdata)
},
nsim = 100
)
View(shap)
