library(hawkesMCEM)
# --- Same simulation setup as earlier ---
horizon <- 20
p_miss  <- 0.15
sim <- simulate_hawkes_missing(
mu = 1.5, alpha = 0.8, beta = 1.2,
horizon = horizon, p_miss = p_miss, seed = 1
)
# --- Observed vs complete MLE (for comparison) ---
mle <- list(
mle_obs  = hawkesMLE(sim$t_obs,  horizon),
mle_comp = hawkesMLE(sim$t_comp, horizon)
)
mle$mle_obs
mle$mle_comp
# -------------------------------
# MCEM + adaptive N (Q-based MCSE)
# -------------------------------
fit_Q <- run_mcem(
sim$t_obs, horizon = horizon, p_miss = p_miss,
proposal = "sequential",
N = 1000, maxit = 10, seed = 123, verbose = TRUE,
adaptive = TRUE,
mcse_rule = "Q",        # default
mcse_tol  = 0.05,
N_max     = 10000L,
N_mult    = 2,
epsilon   = 2           # NEW: z-threshold for "score within MC noise"
)
fit_Q$df_est
# Pick a complete event sequence (e.g. simulated complete data)
t <- sim$t_comp
T <- horizon
theta <- c(mu=2.0, alpha=0.65, beta=1.0)
# Analytic grad
g_ana <- hawkes_llh_grad(t, mu=theta["mu"], alpha=theta["alpha"], beta=theta["beta"], T=T)
# Numeric grad (central diff)
num_grad <- function(theta, h=1e-5) {
f <- function(th) hawkes_llh(t, mu=th[1], alpha=th[2], beta=th[3], T=T)
g <- numeric(3)
for (i in 1:3) {
th1 <- theta; th2 <- theta
th1[i] <- th1[i] + h
th2[i] <- th2[i] - h
g[i] <- (f(th1) - f(th2)) / (2*h)
}
g
}
g_num <- num_grad(unname(theta))
cbind(analytic=g_ana, numeric=g_num, diff=g_ana-g_num)
