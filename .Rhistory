impute_stratified_and_diag <- function(t_obs, horizon, p_miss,
mu, alpha, beta,
N = 200, delta = 0.2,
seed = 999,
K_max = 10L, M_min = 15L,
make_plots = TRUE) {
n_obs <- length(t_obs)
pmf_n_tot <- get_cond_pmf(mu, alpha, beta, n_obs, p_miss, horizon)
strat <- choose_strata_and_alloc(pmf_n_tot, n_obs, N, K_max = K_max, M_min = M_min)
m_strata <- strat$m_strata
pi_k <- strat$pi_k
Mk <- strat$Mk
a_k <- strat$a_k
t_imp_all <- vector("list", sum(Mk))
logw_all <- numeric(sum(Mk))
m_all <- integer(sum(Mk))
idx <- 1L
for (k in seq_along(m_strata)) {
mk <- m_strata[k]
n_tot_k <- n_obs + mk
Mk_k <- Mk[k]
rslt_k <- hawkesMCEM::imputeSequence(
t_obs = t_obs,
N = as.integer(Mk_k),
mu = mu, alpha = alpha,
horizon = horizon, p_miss = p_miss,
beta = beta,
delta = delta,
n_tot_fixed = as.integer(n_tot_k),
seed = as.integer(seed + 1000L * k)
)
logw_time_k <- as.numeric(rslt_k[[2]])
logw_k <- logw_time_k + log(pi_k[k]) - log(a_k[k])
rng <- idx:(idx + Mk_k - 1L)
t_imp_all[rng] <- rslt_k[[1]]
logw_all[rng] <- logw_k
m_all[rng] <- mk
idx <- idx + Mk_k
}
# normalize combined weights
lw_shift <- logw_all - max(logw_all)
w_raw <- exp(lw_shift)
w <- w_raw / sum(w_raw)
ess <- 1 / sum(w^2)
out <- list(
ess = ess,
top10_share = sum(sort(w, decreasing = TRUE)[1:min(10, length(w))]),
quant_w = quantile(w, probs = c(0, .01, .05, .1, .25, .5, .75, .9, .95, .99, 1)),
strata = data.frame(m = m_strata, pi = pi_k, Mk = Mk, a = a_k),
logw = logw_all, w = w, m_all = m_all
)
if (make_plots) {
oldpar <- par(mfrow = c(2, 2))
hist(out$logw, breaks = 40, main = "logw (combined)", xlab = "logw")
hist(out$w, breaks = 40, main = "weights (combined)", xlab = "w")
plot(sort(out$w, decreasing = TRUE), type = "h",
main = sprintf("Sorted weights (ESS=%.1f / N=%d)", out$ess, length(out$w)),
xlab = "rank", ylab = "w")
plot(cumsum(sort(out$w, decreasing = TRUE)), type = "l",
main = "Cumulative mass", xlab = "rank", ylab = "cum sum")
par(oldpar)
}
# within-m ESS (diagnose time-proposal per count)
ess_by_m <- tapply(out$w, out$m_all, function(wm) {
wm <- wm / sum(wm)
1 / sum(wm^2)
})
list(out = out, t_imp_list = t_imp_all, ess_by_m = ess_by_m)
}
# ------------------------------------------------------------
# Example usage
# ------------------------------------------------------------
horizon <- 50
p_miss  <- 0.15
sim <- simulate_hawkes_missing(mu = 1.0, alpha = 0.3, beta = 1.0,
horizon = horizon, p_miss = p_miss, seed = 1)
t_obs <- sim$t_obs
fit <- hawkesMCEM::HawkesEM(t_obs, horizon, p_miss,
N = 200, maxit = 20, delta = 0.2,
seed = 1, verbose = FALSE)
rs <- impute_stratified_and_diag(
t_obs = t_obs, horizon = horizon, p_miss = p_miss,
mu = fit$mu, alpha = fit$alpha, beta = fit$beta,
N = 200, delta = 0.2,
seed = 999, K_max = 10L, M_min = 15L,
make_plots = TRUE
)
