sim$t_obs, horizon = horizon, p_miss = p_miss,
proposal = "sequential",
N = 2000, maxit = 50, seed = 123, verbose = TRUE,
adaptive = TRUE,
mcse_rule = "Q",      # default, can omit
mcse_tol  = 0.05,
N_max     = 20000L,
N_mult    = 2
)
